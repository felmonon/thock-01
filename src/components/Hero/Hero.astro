---
import './Hero.css';
import {
	buildSoundprintPath,
	calibrationEvents,
} from '../../lib/soundprint.js';

const letters = ['T', 'H', 'O', 'C', 'K'];
const factoryPreviewPath = buildSoundprintPath(calibrationEvents, 600, 100);
---

<header class="hero">
	<div class="hero-grid" aria-hidden="true"></div>
	<nav class="hero-nav">
		<span class="hero-logo mono">THOCK/01</span>
		<div class="hero-nav-links mono">
			<a href="#anatomy">Anatomy</a>
			<a href="#switches">Switches</a>
			<a href="#soundprint">Soundprint</a>
		</div>
	</nav>

	<div class="hero-stage">
		<p class="section-label">Mechanical keyboard, mark one</p>
		<h1 class="hero-title" aria-label="THOCK interactive keyboard">
			{letters.map((letter, index) => (
				<button
					class="keycap"
					type="button"
					data-key={letter}
					aria-label={`Play the ${letter} key and add it to your soundprint`}
				>
					<span class="keycap-base" aria-hidden="true"></span>
					<span class="keycap-shell" aria-hidden="true">
						<span class="keycap-face">
							<span class="keycap-index mono">{String(index + 1).padStart(2, '0')}</span>
							<span class="keycap-legend">{letter}</span>
							<span class="keycap-axis mono">MX</span>
						</span>
					</span>
				</button>
			))}
		</h1>
		<p id="hero-subtitle" class="mono">The sound your desk has been waiting for.</p>
		<div class="hero-interaction mono">
			<p class="hero-hint">Type a key or tap a cap. Build your soundprint.</p>
			<button class="sound-toggle" type="button" aria-pressed="true">
				<span class="sound-dot" aria-hidden="true"></span>
				Sound <strong data-sound-state>armed</strong>
			</button>
		</div>
		<div class="hero-soundprint mono" aria-hidden="true">
			<div><span data-hero-soundprint-source>Factory trace</span><strong data-hero-soundprint-count>00</strong></div>
			<svg viewBox="0 0 600 100" preserveAspectRatio="none">
				<line x1="0" y1="50" x2="600" y2="50"></line>
				<path data-hero-soundprint-path d={factoryPreviewPath}></path>
			</svg>
		</div>
	</div>

	<div class="hero-telemetry mono" role="group" aria-label="THOCK/01 specifications">
		<div><span>Layout</span><strong>75%</strong></div>
		<div><span>Mass</span><strong>2.1 kg</strong></div>
		<div><span>Angle</span><strong>6.5°</strong></div>
		<div><span>Profile</span><strong data-profile-display>Tactile</strong></div>
		<a href="#anatomy">Scroll to disassemble <span aria-hidden="true">↓</span></a>
	</div>

	<div class="hero-impact" aria-hidden="true"></div>
</header>

<script>
	import './Hero.js';
</script>
